# GramAI Environment Configuration
# Copy this file to .env and modify as needed

# Claude API Configuration
ANTHROPIC_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-haiku-20240307

# Vosk STT Model Path (download Hindi model from https://alphacephei.com/vosk/models)
VOSK_MODEL_PATH=./models/vosk-model-hi

# TTS Engine
TTS_ENGINE=pyttsx3

# Server Configuration
HOST=0.0.0.0
PORT=8000
