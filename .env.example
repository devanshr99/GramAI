# GramAI Environment Configuration
# Copy this file to .env and modify as needed

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Vosk STT Model Path (download Hindi model from https://alphacephei.com/vosk/models)
VOSK_MODEL_PATH=./models/vosk-model-hi

# TTS Engine
TTS_ENGINE=pyttsx3

# Server Configuration
HOST=0.0.0.0
PORT=8000
